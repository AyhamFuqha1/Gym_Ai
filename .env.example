APP_NAME=FitMind AI Service
DEBUG=false
HOST=0.0.0.0
PORT=8001
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2-preview

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=your_openrouter_model

CHROMA_PATH=chroma_gym
EXERCISES_COLLECTION=exercises_data
NUTRITION_COLLECTION=nutrition_data

EXERCISES_MANIFEST=gym_manifest.json
NUTRITION_MANIFEST=nutrition_manifest.json
CHECKPOINT_FILE=./data/sync_checkpoint.json
BATCH_SIZE=50
SYNC_DELAY_SECONDS=1.0

INTERNAL_AI_API_TOKEN=your_internal_ai_api_token
